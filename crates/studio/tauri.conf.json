{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noema Atlas Studio",
  "version": "2.0.0-alpha.2",
  "identifier": "com.noemaai.studio",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Noema Atlas Studio",
        "width": 1040,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2RjlBRDRDRUZFMkM2OUQKUldTZHh1THZUSzM1dHFBeXBXUmpuaXh1dG1YOWhrSFFxcEV0aE8wL1NQMUMyZzR0ak5FeFJsZEkK",
      "endpoints": [
        "https://atlas.noemaai.com/studio/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
